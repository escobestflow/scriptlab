ANTHROPIC_API_KEY=sk-ant-paste-your-key-here

# Resend — required for /api/send-email (project-bundle email feature).
# Create a free API key at https://resend.com/api-keys
RESEND_API_KEY=re_paste-your-key-here

# Optional. Defaults to Resend's shared sandbox sender (onboarding@resend.dev)
# which is fine for dev but flags in real inboxes. Swap to a domain-verified
# address (e.g. "Unfold <hello@yourdomain.com>") once DNS is wired.
# EMAIL_FROM=Unfold <onboarding@resend.dev>

# Optional. Embedded as the "Open in Unfold →" link in email footers.
# If unset, the send route derives it from the request's Origin header.
# APP_URL=https://your-app.example.com

# Optional. Comma-separated list of emails that should see the v2
# redesign. Everyone else (and signed-out viewers) see v1. Used by the
# pre-hydration design bootstrap in app/layout.tsx + the runtime
# refresh in lib/auth.tsx. Case-insensitive; whitespace trimmed.
# Example: NEXT_PUBLIC_V2_EMAILS=sam@unfold.dev,designer@unfold.dev
# NEXT_PUBLIC_V2_EMAILS=
